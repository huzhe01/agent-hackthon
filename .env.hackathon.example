# GrowEngine 智投星 Agent - 黑客松部署环境变量模板
# 复制为 `.env.hackathon` 后填写真实密钥：
#   cp .env.hackathon.example .env.hackathon

# 前端公网端口。服务器上如已有 3000，可改为 8080/18080。
APP_PORT=3000

# Vite 构建期 API 地址。
# 留空表示浏览器请求同域 `/api`，由 Nginx 反向代理到后端容器。
VITE_API_BASE_URL=

# 模型路由服务，兼容 OpenAI Chat Completions 的 /v1 接口。
# 现场如提供 SkyRouter / 小宿模型路由资源，只需要替换这三项。
LLM_API_BASE=https://680728.xyz/v1
LLM_MODEL=qwen-max
LLM_API_KEY=replace-with-your-hackathon-key

# 可选：如果现场提供搜索/API/沙盒资源，把 Key 填在这里，后续工具可读取。
XIAOSU_SEARCH_API_KEY=
SKYROUTER_API_KEY=
AI_SANDBOX_API_KEY=
