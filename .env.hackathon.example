# GrowEngine 智投星 Agent - 黑客松部署环境变量模板
# 复制为 `.env.hackathon` 后填写真实密钥：
#   cp .env.hackathon.example .env.hackathon

# 前端公网端口。服务器上如已有 3000，可改为 8080/18080。
APP_PORT=3000

# Vite 构建期 API 地址。
# 留空表示浏览器请求同域 `/api`，由 Nginx 反向代理到后端容器。
VITE_API_BASE_URL=

# Qiji OpenAI-compatible 服务。后端默认用 qiji_api.md 已验证的 gpt-5。
QIJI_BASE_URL=https://api.openai-next.com/v1
QIJI_MODEL=gpt-5
QIJI_API_KEY=replace-with-your-qiji-key

# 兼容旧变量：如果没有设置 QIJI_API_KEY，后端会尝试读取 LLM_API_KEY。
LLM_API_BASE=https://api.openai-next.com/v1
LLM_MODEL=gpt-5
LLM_API_KEY=

# 可选：小宿/Cloudsway SmartSearch。请求头是 Authorization: key，不加 Bearer。
CLOUDSWAY_SEARCH_KEY=
XIAOSU_SEARCH_API_KEY=

# 可选：如果现场提供其他 API/沙盒资源，把 Key 填在这里，后续工具可读取。
SKYROUTER_API_KEY=
AI_SANDBOX_API_KEY=
